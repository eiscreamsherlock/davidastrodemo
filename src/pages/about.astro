---
import BaseLayout from '../layouts/BaseLayout.astro'

const pageTitle = "About Me";

const identity = {
  firstName: "Bill",
  country: "Murica",
  occupation: "Sunnvabitch",
  hobbies: ["drinking", "horseback riding", "gambling"],
};

const skills = ["Poker", "Drinking", "Drink Mixing", "Philandering", "Philanthropy"];

const happy = true;
const finished = false;
const goal = 42;

const skillColor = "crimson";
const fontWeight = "bold";
const textCase = "uppercase";
---
<BaseLayout pageTitle={pageTitle}>
    <style define:vars={{skillColor, fontWeight, textCase}}>
      .skill {
        color: var(--skillColor);
        font-weight: var(--fontWeight);
        text-transform: var(--textCase);
      }
    </style>
    <h2>...and my new-fangled Astroboy site.</h2>
    <p>Some text about what this is all about will go here.</p>

    <p>I am working through Astro's introductory tutorial. This is the second page on my website.</p>

    <p>This site will update as I complete more of the tutorial (likely).</p>
    <p>Here are some facts about Bill:</p>
    <ul>
      <li>My name is {identity.firstName}.</li>
      <li>I live in {identity.country}.</li>
      { identity.hobbies.length >= 2 &&
        <li>Two of my favorite passtimes are {identity.hobbies[0]} and {identity.hobbies[1]}</li>
      }
    </ul>
    <p>My skills are:</p>
    <ul>
      {skills.map((skill) => <li class="skill">{skill}</li>)}
    </ul>

    {happy && <p>I am happy to be learning Astronomicon.</p>}

    {finished && <p>I finished the whole tutorial!</p>}

    {goal === 3 ? <p>My goal is to finish in 3 days.</p> : <p>My goal is not 3 days.</p>
</BaseLayout>
